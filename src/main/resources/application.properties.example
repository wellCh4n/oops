spring.application.name=oops
spring.autoconfigure.exclude=org.springframework.boot.autoconfigure.security.servlet.UserDetailsServiceAutoConfiguration

spring.datasource.url=jdbc:sqlite:oops.db
spring.datasource.driver-class-name=org.sqlite.JDBC
spring.jpa.database-platform=org.hibernate.community.dialect.SQLiteDialect

spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.open-in-view=true
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration/sqlite
spring.flyway.baseline-on-migrate=true
spring.flyway.baseline-version=1

oops.pipeline.image.clone=alpine/git:v2.49.0
oops.pipeline.image.zip=alpine/curl:8.17.0
oops.pipeline.image.push=gcr.io/kaniko-project/executor:v1.23.2
oops.pipeline.image.kaniko-registry-map=index.docker.io=docker.m.daocloud.io
oops.ingress.cert-resolver=letsencrypt-prod

oops.object-storage.enabled=false
oops.object-storage.endpoint=https://s3.oss-cn-hangzhou.aliyuncs.com
oops.object-storage.region=cn-hangzhou
oops.object-storage.bucket=oops-build-sources
oops.object-storage.access-key=
oops.object-storage.secret-key=
oops.object-storage.path-style-access=false
oops.object-storage.key-prefix=build-sources
oops.object-storage.upload-url-expiration-seconds=900
oops.object-storage.download-url-expiration-seconds=1800
oops.object-storage.max-file-size-bytes=524288000

oops.crypto.secret-key=oops-crypto-secret-key-please-change-in-production

oops.jwt.secret=oops-jwt-secret-key-please-change-in-production-must-be-at-least-32-chars
oops.jwt.expiration=604800000

oops.feishu.enabled=false
oops.feishu.app-id=cli_xxx
oops.feishu.app-secret=xxx
oops.feishu.redirect-uri=http://localhost:3000/auth/feishu/callback

oops.ide.enabled=false
oops.ide.https=false
oops.ide.domain=ide.k8s.orb.local
oops.ide.image=codercom/code-server:4.112.0-39
oops.ide.middleware=code-server-csp-fix,code-server-oss-redirect
oops.ide.proxy-domain={{port}}-{{host}}
