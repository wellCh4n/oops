spring:
  application:
    name: oops
  autoconfigure:
    exclude: org.springframework.boot.autoconfigure.security.servlet.UserDetailsServiceAutoConfiguration
  datasource:
    # ----- Scenario A: docker-compose.yml (bundled mysql via compose network) -----
    url: jdbc:mysql://mysql:3306/oops?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8&useUnicode=true
    username: oops
    password: oops
    # ----- Scenario B: docker-compose.local.yml (external mysql on host) -----
    # url: jdbc:mysql://host.docker.internal:3306/oops?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8&useUnicode=true
    # username: <your_user>
    # password: <your_password>
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    database-platform: org.hibernate.dialect.MySQLDialect
    hibernate:
      ddl-auto: none
    show-sql: false
    open-in-view: false
  flyway:
    enabled: true
    baseline-on-migrate: true
    baseline-version: 1

oops:
  admin:
    password: admin123
  jwt:
    secret: oops-jwt-secret-key-please-change-in-production-must-be-at-least-32-chars
    expiration: 604800000
  crypto:
    secret-key: oops-crypto-secret-key-please-change-in-production
  ingress:
    cert-resolver: letsencrypt-prod
  pipeline:
    image:
      clone: alpine/git:v2.49.0
      zip: alpine/curl:8.17.0
      push: quay.io/buildah/stable:v1.43.1
      registry-mirrors:
        docker.io: docker.m.daocloud.io
      unzip-excludes:
        - .git/*
        - "*/.git/*"
        - node_modules/*
        - "*/node_modules/*"
        - __MACOSX
        - __MACOSX/*
        - "*/__MACOSX"
        - "*/__MACOSX/*"
        - .DS_Store
        - "*/.DS_Store"
  pod-filesystem:
    max-download-size-bytes: 52428800
    max-upload-size-bytes: 52428800
    max-edit-size-bytes: 1048576
  feishu:
    enabled: false
    app-id: cli_xxx
    app-secret: xxx
    redirect-uri: http://localhost:3000/auth/feishu/callback
  ide:
    enabled: false
    https: false
    domain: ide.k8s.example.com
    image: codercom/code-server:4.112.0-39
    middlewares:
      - code-server-csp-fix
      - code-server-oss-redirect
    proxy-domain: "{{port}}-{{host}}"
  object-storage:
    enabled: false
    endpoint: https://s3.oss-cn-hangzhou.aliyuncs.com
    region: cn-hangzhou
    bucket: oops-build-sources
    access-key:
    secret-key:
    path-style-access: false
    key-prefix: build-sources
    asset-key-prefix: oops-assets
    asset-base-url:
    upload-url-expiration-seconds: 900
    download-url-expiration-seconds: 1800
    max-file-size-bytes: 524288000
  sandbox:
    images:
      - python:3.12-slim
      - node:20-slim
