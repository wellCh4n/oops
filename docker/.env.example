# ============================================================
# OOPS Environment Variables
# Copy this file to .env and fill in your values.
# These override application.yml when running via Docker.
# ============================================================

# ===== Database =====
# For docker-compose.local.yml: point to your external MySQL host
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/oops?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8&useUnicode=true
SPRING_DATASOURCE_USERNAME=oops
SPRING_DATASOURCE_PASSWORD=your_password_here
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect

# ===== Admin =====
ADMIN_PASSWORD=admin123

# ===== Security =====
OOPS_JWT_SECRET=oops-jwt-secret-key-please-change-in-production-must-be-at-least-32-chars
OOPS_JWT_EXPIRATION=604800000
OOPS_CRYPTO_SECRET_KEY=oops-crypto-secret-key-please-change-in-production

# ===== Ingress =====
OOPS_INGRESS_CERT_RESOLVER=letsencrypt-prod

# ===== Pipeline Images =====
OOPS_PIPELINE_IMAGE_CLONE=alpine/git:v2.49.0
OOPS_PIPELINE_IMAGE_ZIP=alpine/curl:8.17.0
OOPS_PIPELINE_IMAGE_PUSH=quay.io/buildah/stable:v1.43.1

# Registry mirrors — map key is registry host (dots become underscores)
OOPS_PIPELINE_IMAGE_REGISTRY_MIRRORS_DOCKER_IO=docker.m.daocloud.io

# Unzip excludes — indexed array
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_0=.git/*
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_1=*/.git/*
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_2=node_modules/*
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_3=*/node_modules/*
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_4=__MACOSX
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_5=__MACOSX/*
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_6=*/__MACOSX
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_7=*/__MACOSX/*
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_8=.DS_Store
OOPS_PIPELINE_IMAGE_UNZIP_EXCLUDES_9=*/.DS_Store

# ===== Pod Filesystem =====
OOPS_POD_FILESYSTEM_MAX_DOWNLOAD_SIZE_BYTES=52428800

# ===== Feishu / Lark OAuth (optional) =====
OOPS_FEISHU_ENABLED=false
OOPS_FEISHU_APP_ID=cli_xxx
OOPS_FEISHU_APP_SECRET=your_app_secret_here
OOPS_FEISHU_REDIRECT_URI=http://localhost:3000/auth/feishu/callback

# ===== IDE / code-server (optional) =====
OOPS_IDE_ENABLED=false
OOPS_IDE_HTTPS=false
OOPS_IDE_DOMAIN=ide.k8s.example.com
OOPS_IDE_IMAGE=codercom/code-server:4.112.0-39
# Middlewares — indexed array
OOPS_IDE_MIDDLEWARES_0=code-server-csp-fix
OOPS_IDE_MIDDLEWARES_1=code-server-oss-redirect
# Port proxy template — must contain both {{port}} and {{host}}
OOPS_IDE_PROXY_DOMAIN={{port}}-{{host}}

# ===== Object Storage (optional, for ZIP source uploads) =====
OOPS_OBJECT_STORAGE_ENABLED=false
OOPS_OBJECT_STORAGE_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com
OOPS_OBJECT_STORAGE_REGION=cn-hangzhou
OOPS_OBJECT_STORAGE_BUCKET=oops-build-sources
OOPS_OBJECT_STORAGE_ACCESS_KEY=
OOPS_OBJECT_STORAGE_SECRET_KEY=
OOPS_OBJECT_STORAGE_PATH_STYLE_ACCESS=false
OOPS_OBJECT_STORAGE_KEY_PREFIX=build-sources
OOPS_OBJECT_STORAGE_UPLOAD_URL_EXPIRATION_SECONDS=900
OOPS_OBJECT_STORAGE_DOWNLOAD_URL_EXPIRATION_SECONDS=1800
OOPS_OBJECT_STORAGE_MAX_FILE_SIZE_BYTES=524288000

# ===== Sandbox =====
# Available runtime images — indexed array
OOPS_SANDBOX_IMAGES_0=python:3.12-slim
OOPS_SANDBOX_IMAGES_1=node:20-slim
